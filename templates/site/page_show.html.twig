{% extends 'site/layout.html.twig' %}

{% block title %}{{ page.sharingDocumentTitle }}{% endblock %}

{% block meta %}
    {% include 'site/_head_seo.html.twig' %}
{% endblock %}

{% block nav %}
    {% include 'site/_nav.html.twig' %}
{% endblock %}

{% block body %}
    <main id="contenu" class="stack">
        {% for section in page.enabledSections %}
            {% include section.kind.template() with {
                section,
            } only %}
        {% endfor %}
    </main>
{% endblock %}

{% block footer %}
    {% include 'site/_footer.html.twig' %}
{% endblock %}
