{# @var page \App\Entity\Page #}
{% set fp = page.footerPayload ?? {} %}
<footer class="stack border-t border-ink/15">
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
        <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 sm:items-end">
            <div>
                {% set footerRich = fp.footerContentHtml ?? '' %}
                {% if footerRich|trim %}
                    {# Admin-edited HTML: trust ROLE_ADMIN-authored content similarly to generic page blocks #}
                    <div class="text-sm leading-relaxed text-ink/80 [&_a]:font-semibold [&_a]:text-accent [&_a]:underline-offset-2 hover:[&_a]:underline">
                        {{ footerRich|raw }}
                    </div>
                {% else %}
                    {# Legacy payloads that still store separate scalars — remove after next save without rich content fallback #}
                    <div class="font-display text-lg font-black tracking-tight">
                        {{ fp.footerBrand ?? page.title }}
                    </div>
                    <div class="mt-3 space-y-1 text-sm text-ink/70">
                        {% if fp.footerEmail is defined and fp.footerEmail %}
                            <div>
                                <a class="transition-colors duration-200 hover:text-accent focus:text-accent"
                                   href="mailto:{{ fp.footerEmail }}">{{ fp.footerEmail }}</a>
                            </div>
                        {% endif %}
                        {% if fp.footerPhone is defined and fp.footerPhone %}
                            <div>
                                <a class="transition-colors duration-200 hover:text-accent focus:text-accent"
                                   href="tel:{{ fp.footerPhoneHref ?? fp.footerPhone|replace({' ': '', '.': ''}) }}">{{ fp.footerPhone }}</a>
                            </div>
                        {% endif %}
                    </div>
                {% endif %}
            </div>

            <div class="sm:text-right">
                {% if fp.socialTitle is defined and fp.socialTitle %}
                    <div class="text-xs font-semibold uppercase tracking-widest text-ink/70">
                        {{ fp.socialTitle }}
                    </div>
                {% endif %}
                <div class="mt-4 flex items-center gap-4 sm:justify-end">
                    {% for link in fp.socialLinks ?? [] %}
                        {% set hasIcon = link.icon is defined and link.icon %}
                        <a class="inline-flex items-center gap-2 border border-ink px-3 py-2 text-sm font-semibold transition-colors duration-200 hover:border-accent hover:text-accent focus:border-accent focus:text-accent"
                           href="{{ link.url }}"
                           aria-label="{{ link.label|e('html_attr') }}"
                           {% if link.target is defined and link.target %}target="{{ link.target }}" rel="noopener noreferrer"{% endif %}
                        >
                            {% if hasIcon %}
                                <i data-lucide="{{ link.icon }}" class="h-4 w-4"></i>
                            {% endif %}
                            {# Without an icon the label must stay visible on narrow screens too #}
                            <span class="{{ hasIcon ? 'hidden sm:inline' : '' }}">{{ link.label }}</span>
                        </a>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="mt-10 flex items-center justify-between border-t border-ink/15 pt-6">
            <p class="text-xs text-ink/55">
                © {{ 'now'|date('Y') }} {{ fp.copyrightName ?? page.title }}{% if fp.copyrightTagline %} — {{ fp.copyrightTagline }}{% endif %}
            </p>
            <a href="#top"
               class="text-xs font-semibold transition-colors duration-200 hover:text-accent focus:text-accent"
            >Haut de page</a>
        </div>
    </div>
</footer>
